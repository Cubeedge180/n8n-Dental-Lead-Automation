# ─── n8n Instance ───────────────────────────────────────
N8N_BASE_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here

# ─── OpenAI (used for AI-powered nodes) ────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─── Google Sheets (central data store) ────────────────
GOOGLE_SHEETS_CREDENTIALS_JSON=path/to/credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ─── Google Calendar (appointment sync) ────────────────
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ─── Email / SMTP ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=clinic@yourdomain.com
SMTP_PASS=your_app_password_here
EMAIL_FROM_NAME=Your Dental Clinic

# ─── WhatsApp Business (optional) ──────────────────────
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Webhook Base URL ──────────────────────────────────
WEBHOOK_BASE_URL=https://your-instance.app.n8n.cloud/webhook
